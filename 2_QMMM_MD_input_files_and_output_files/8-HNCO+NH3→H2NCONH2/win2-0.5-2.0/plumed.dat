UPPER_WALLS ARG=hd1 AT=3.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=hwall1
UPPER_WALLS ARG=hd2 AT=3.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=hwall2
UPPER_WALLS ARG=a1 AT=0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall1
LOWER_WALLS ARG=a1 AT=-0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall2
UPPER_WALLS ARG=a2 AT=0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall3
LOWER_WALLS ARG=a2 AT=-0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall4
UPPER_WALLS ARG=a3 AT=0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall5
LOWER_WALLS ARG=a3 AT=-0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall6
UPPER_WALLS ARG=a4 AT=0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall7
LOWER_WALLS ARG=a4 AT=-0.50 KAPPA=50.0 EXP=2 EPS=1 OFFSET=0 LABEL=awall8

d1C-N: DISTANCE ATOMS=1,8 NOPBC
d2N-H: DISTANCE ATOMS=8,9 NOPBC
d3N-H: DISTANCE ATOMS=9,3 NOPBC
d4O-H: DISTANCE ATOMS=3,7 NOPBC
d5H-N: DISTANCE ATOMS=7,4 NOPBC
d6N-O: DISTANCE ATOMS=8,3 NOPBC
d7O-N: DISTANCE ATOMS=3,4 NOPBC
d8N-C: DISTANCE ATOMS=4,1 NOPBC
fun1: MATHEVAL ARG=d1C-N,d2N-H,d3N-H,d4O-H,d5H-N VAR=d1,d2,d3,d4,d5 FUNC=d1-d2+d3-d4+d5 PERIODIC=NO
fun2: MATHEVAL ARG=d1C-N,d2N-H,d3N-H,d4O-H,d5H-N VAR=d1,d2,d3,d4,d5 FUNC=d1+d2+d3+d4+d5 PERIODIC=NO
fun3: MATHEVAL ARG=d1C-N,d6N-O,d7O-N,d8N-C VAR=d1,d2,d3,d4 FUNC=d1+d2+d3+d4 PERIODIC=NO
fun4: MATHEVAL ARG=d2N-H,d3N-H,d4O-H,d5H-N VAR=d1,d2,d3,d4 FUNC=d1+d4-d2-d3 PERIODIC=NO
UPPER_WALLS ARG=fun2 AT=7.80 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall2
UPPER_WALLS ARG=fun3 AT=8.80 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall3
UPPER_WALLS ARG=fun4 AT=1.00 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall4
LOWER_WALLS ARG=fun4 AT=-1.00 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=downwall4
UPPER_WALLS ARG=d1C-N AT=1.75 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall5
UPPER_WALLS ARG=d2N-H AT=2.60 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall6
LOWER_WALLS ARG=d2N-H AT=1.40 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=downwall6

UPPER_WALLS ARG=fun1 AT=2.20 KAPPA=150.0 EXP=2 EPS=1 OFFSET=0 LABEL=upwall1
LOWER_WALLS ARG=fun1 AT=0.30 KAPPA=150.0 EXP=2 EPS=1 OFFSET=0 LABEL=downwall1

METAD ...
 LABEL=metad
 ARG=fun1
 PACE=50
 HEIGHT=0.30
 SIGMA=0.10
 FILE=HILLS
 CALC_RCT
 GRID_MIN=-15.0
 GRID_MAX=15.0
 GRID_BIN=400
 TEMP=300
...

FLUSH STRIDE=10
PRINT STRIDE=1 ARG=fun1,fun2,fun3,fun4,d1C-N,d1C-N FILE=cv.txt