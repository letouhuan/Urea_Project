UPPER_WALLS ARG=hd1 AT=3.50 KAPPA=400.0 EXP=2 EPS=1 OFFSET=0 LABEL=hwall1
UPPER_WALLS ARG=hd2 AT=3.50 KAPPA=400.0 EXP=2 EPS=1 OFFSET=0 LABEL=hwall2
UPPER_WALLS ARG=ha1 AT=0.50 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=awall1
LOWER_WALLS ARG=ha1 AT=-0.50 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=awall2
UPPER_WALLS ARG=ha2 AT=0.50 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=awall3
LOWER_WALLS ARG=ha2 AT=-0.50 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=awall4

sd1: DISTANCE ATOMS=4,6 
sd2: DISTANCE ATOMS=8,10
sd3: DISTANCE ATOMS=3,5
sd4: DISTANCE ATOMS=1,2 
UPPER_WALLS ARG=sd1 AT=1.02 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=swall1
UPPER_WALLS ARG=sd2 AT=1.02 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=swall2
UPPER_WALLS ARG=sd3 AT=1.02 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=swall3
UPPER_WALLS ARG=sd4 AT=1.40 KAPPA=50.00 EXP=2 EPS=1 OFFSET=0 LABEL=swall4

d1C-O: DISTANCE ATOMS=1,3 NOPBC
d2O-H: DISTANCE ATOMS=3,9 NOPBC
d3H-O: DISTANCE ATOMS=9,8 NOPBC
d4O-H: DISTANCE ATOMS=8,7 NOPBC
d5H-N: DISTANCE ATOMS=7,4 NOPBC
d6N-C: DISTANCE ATOMS=4,1 NOPBC
d7O-O: DISTANCE ATOMS=3,8 NOPBC
d8O-N: DISTANCE ATOMS=8,4 NOPBC
fun1: MATHEVAL ARG=d1C-O,d2O-H,d3H-O,d4O-H,d5H-N VAR=d1,d2,d3,d4,d5 FUNC=d1-d2+d3-d4+d5 PERIODIC=NO
fun2: MATHEVAL ARG=d1C-O,d2O-H,d3H-O,d4O-H,d5H-N VAR=d1,d2,d3,d4,d5 FUNC=d1+d2+d3+d4+d5 PERIODIC=NO
fun3: MATHEVAL ARG=d1C-O,d7O-O,d8O-N,d6N-C VAR=d1,d2,d3,d4 FUNC=d1+d2+d3+d4 PERIODIC=NO
fun4: MATHEVAL ARG=d5H-N,d4O-H,d3H-O,d2O-H VAR=d1,d2,d3,d4 FUNC=d1+d4-d2-d3 PERIODIC=NO
UPPER_WALLS ARG=fun2 AT=9.0 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall1
UPPER_WALLS ARG=fun3 AT=10.50 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall2
UPPER_WALLS ARG=fun4 AT=1.00 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall3
LOWER_WALLS ARG=fun4 AT=-1.00 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=downwall3
UPPER_WALLS ARG=d1C-O AT=3.20 KAPPA=300.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall4
LOWER_WALLS ARG=d1C-O AT=1.75 KAPPA=300.00 EXP=2 EPS=1 OFFSET=0 LABEL=downwall4
UPPER_WALLS ARG=d5H-N AT=1.80 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall5
UPPER_WALLS ARG=d6N-C AT=1.36 KAPPA=100.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall6

UPPER_WALLS ARG=fun1 AT=3.70 KAPPA=200.00 EXP=2 EPS=1 OFFSET=0 LABEL=upwall7
LOWER_WALLS ARG=fun1 AT=2.30 KAPPA=200.00 EXP=2 EPS=1 OFFSET=0 LABEL=downwall7

METAD ...
 LABEL=metad
 ARG=fun1
 PACE=50
 HEIGHT=0.2
 SIGMA=0.10
 FILE=HILLS
 CALC_RCT
 GRID_MIN=-8.0
 GRID_MAX=8.0
 GRID_BIN=400
 TEMP=300
...

FLUSH STRIDE=10
PRINT STRIDE=1 ARG=fun1,fun2,fun3,fun4,d1C-O,d5H-N,d6N-C FILE=cv.txt