RESTART
UNITS LENGTH=A ENERGY=kcal/mol
v1: FIXEDATOM AT=0.00,0.00,0.00
d1: DISTANCE ATOMS=v1,1 COMPONENTS NOPBC
d2: DISTANCE ATOMS=v1,4 COMPONENTS NOPBC
d3: DISTANCE ATOMS=1,4 NOPBC
LOWER_WALLS ARG=d1.z AT=57.00 KAPPA=200.00 EXP=2 EPS=1 OFFSET=0 LABEL=wall1
LOWER_WALLS ARG=d2.z AT=57.00 KAPPA=200.00 EXP=2 EPS=1 OFFSET=0 LABEL=wall2
PRINT STRIDE=1000 ARG=d1.z,d2.z,d3 FILE=cv.txt
