fun5: MATHEVAL ARG=dh10,d2_C-O VAR=d1,d2 FUNC=d1-d2 PERIODIC=NO

UPPER_WALLS ARG=fun2 AT=9.50 KAPPA=100.0 EXP=2 EPS=1 OFFSET=0 LABEL=upwall2
