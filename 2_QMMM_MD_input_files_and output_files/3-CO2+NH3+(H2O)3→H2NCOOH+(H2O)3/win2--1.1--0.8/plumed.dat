fun1: MATHEVAL ARG=d1_N-C,d2_N-H,d15_H-O1,d3_O-H,d16_H-O2,d4_O-H,d17_H-O3,d5_O-H,d18_H-O4 VAR=d1,d2,d3,d4,d5,d6,d7,d8,d9 FUNC=(d1-d2+d3-d4+d5-d6+d7-d8+d9)/2 PERIODIC=NO
